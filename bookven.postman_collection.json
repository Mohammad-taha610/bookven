{
  "info": {
    "name": "Bookven API v1",
    "description": "Sports facility booking API. Set variables: base_url, token. Optional: branch_id, court_id, booking_id, user_id.\n\nPublic (no token): app/config, slots/times, register, login, password/*.\nAll other routes require Authorization: Bearer {{token}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000" },
    { "key": "token", "value": "" },
    { "key": "branch_id", "value": "1" },
    { "key": "court_id", "value": "1" },
    { "key": "booking_id", "value": "1" },
    { "key": "user_id", "value": "1" }
  ],
  "item": [
    {
      "name": "Public",
      "item": [
        {
          "name": "App config",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json", "type": "text" }],
            "url": "{{base_url}}/api/v1/app/config"
          }
        },
        {
          "name": "Slots times grid",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json", "type": "text" }],
            "url": "{{base_url}}/api/v1/slots/times"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" },
              { "key": "Accept", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman User\",\n  \"email\": \"postman@bookven.test\",\n  \"password\": \"password12\",\n  \"password_confirmation\": \"password12\",\n  \"phone\": \"+10000000099\"\n}"
            },
            "url": "{{base_url}}/api/v1/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" },
              { "key": "Accept", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"player@bookven.test\",\n  \"password\": \"password\",\n  \"device_name\": \"postman\"\n}"
            },
            "url": "{{base_url}}/api/v1/login"
          }
        },
        {
          "name": "Me (current user)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": "{{base_url}}/api/v1/user"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": "{{base_url}}/api/v1/logout"
          }
        },
        {
          "name": "Password forgot",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" },
              { "key": "Accept", "value": "application/json", "type": "text" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"player@bookven.test\"\n}" },
            "url": "{{base_url}}/api/v1/password/forgot"
          }
        },
        {
          "name": "Password reset",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" },
              { "key": "Accept", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"player@bookven.test\",\n  \"password\": \"newpassword12\",\n  \"password_confirmation\": \"newpassword12\",\n  \"token\": \"REPLACE_WITH_RESET_TOKEN\"\n}"
            },
            "url": "{{base_url}}/api/v1/password/reset"
          }
        }
      ]
    },
    {
      "name": "Indoor types & branches",
      "item": [
        {
          "name": "Indoor types (Court / Net)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": "{{base_url}}/api/v1/indoor-types"
          }
        },
        {
          "name": "List branches",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": "{{base_url}}/api/v1/branches"
          }
        },
        {
          "name": "Branch courts",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": "{{base_url}}/api/v1/branches/{{branch_id}}/courts"
          }
        },
        {
          "name": "Branch slot board (all courts, date, optional kind)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": "{{base_url}}/api/v1/branches/{{branch_id}}/slot-board?date=2026-04-19&indoor_facility_kind=court"
          }
        },
        {
          "name": "Court detail",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": "{{base_url}}/api/v1/courts/{{court_id}}"
          }
        }
      ]
    },
    {
      "name": "Slots",
      "item": [
        {
          "name": "Court slots (date)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": "{{base_url}}/api/v1/courts/{{court_id}}/slots?date=2026-04-19"
          }
        },
        {
          "name": "Court availability",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": "{{base_url}}/api/v1/courts/{{court_id}}/availability?date=2026-04-19"
          }
        },
        {
          "name": "Slots quick",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": "{{base_url}}/api/v1/slots/quick?court_id={{court_id}}&date=2026-04-19"
          }
        }
      ]
    },
    {
      "name": "Screens",
      "item": [
        {
          "name": "Home screen",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": "{{base_url}}/api/v1/screens/home"
          }
        },
        {
          "name": "New booking screen",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": "{{base_url}}/api/v1/screens/booking-new?branch_id={{branch_id}}"
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Bookings today",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": "{{base_url}}/api/v1/bookings/today"
          }
        },
        {
          "name": "List bookings",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "description": "Staff: add all=1 to list bookings for all users in scope. Optional: date, branch_id, indoor_facility_kind (court|net).",
            "url": "{{base_url}}/api/v1/bookings?all=1&date=2026-04-19&branch_id={{branch_id}}&indoor_facility_kind=court"
          }
        },
        {
          "name": "Create booking",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" },
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"court_id\": {{court_id}},\n  \"slot_id\": 1,\n  \"date\": \"2026-04-19\",\n  \"advance_amount\": \"20.00\",\n  \"customer_name\": \"Demo Customer\",\n  \"customer_phone\": \"+923001234567\"\n}"
            },
            "description": "Optional total_amount (staff only) overrides calculated price.",
            "url": "{{base_url}}/api/v1/bookings"
          }
        },
        {
          "name": "Booking detail",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": "{{base_url}}/api/v1/bookings/{{booking_id}}"
          }
        },
        {
          "name": "Confirm booking",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" },
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"payment_method\": \"Online\"\n}" },
            "url": "{{base_url}}/api/v1/bookings/{{booking_id}}/confirm"
          }
        },
        {
          "name": "Cancel booking",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": "{{base_url}}/api/v1/bookings/{{booking_id}}/cancel"
          }
        },
        {
          "name": "Pay booking",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" },
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"payment_method\": \"Cash\",\n  \"amount\": \"45.00\"\n}" },
            "url": "{{base_url}}/api/v1/bookings/{{booking_id}}/pay"
          }
        },
        {
          "name": "Screen: confirmation",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": "{{base_url}}/api/v1/bookings/{{booking_id}}/screen/confirmation"
          }
        },
        {
          "name": "Screen: confirmed",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": "{{base_url}}/api/v1/bookings/{{booking_id}}/screen/confirmed"
          }
        }
      ]
    },
    {
      "name": "Payments & history",
      "item": [
        {
          "name": "Payment status",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": "{{base_url}}/api/v1/payments/1"
          }
        },
        {
          "name": "User history",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": "{{base_url}}/api/v1/users/{{user_id}}/history"
          }
        }
      ]
    },
    {
      "name": "Staff (role-gated)",
      "item": [
        {
          "name": "Create branch (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" },
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"East Side Pitches\",\n  \"address\": \"500 Field St\",\n  \"phone\": \"+15550003333\",\n  \"opening_hours\": \"Daily 07:00–22:00\"\n}"
            },
            "url": "{{base_url}}/api/v1/branches"
          }
        },
        {
          "name": "Update branch (admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" },
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"East Side Pitches Updated\",\n  \"address\": \"500 Field St\",\n  \"phone\": \"+15550003333\",\n  \"opening_hours\": \"Daily 07:00–22:00\"\n}"
            },
            "url": "{{base_url}}/api/v1/branches/{{branch_id}}"
          }
        },
        {
          "name": "Delete branch (admin)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": "{{base_url}}/api/v1/branches/{{branch_id}}"
          }
        },
        {
          "name": "Create court (admin|manager)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" },
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"branch_id\": {{branch_id}},\n  \"name\": \"Pitch C\",\n  \"type\": \"Outdoor\",\n  \"indoor_facility_kind\": \"court\",\n  \"capacity\": 12,\n  \"price_per_hour\": \"42.00\"\n}"
            },
            "url": "{{base_url}}/api/v1/courts"
          }
        },
        {
          "name": "Update court (admin|manager)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" },
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Pitch C Updated\",\n  \"price_per_hour\": \"44.00\"\n}"
            },
            "url": "{{base_url}}/api/v1/courts/{{court_id}}"
          }
        },
        {
          "name": "Delete court (admin|manager)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": "{{base_url}}/api/v1/courts/{{court_id}}"
          }
        }
      ]
    }
  ]
}
